{ "languageserver": {
    "ccls": {
      "command": "ccls",
      "args": ["--log-file=/tmp/ccls.log", "-v=1"],
      "filetypes": ["c", "cc", "cpp", "c++", "objc", "objcpp"],
      "rootPatterns": [".ccls", "compile_commands.json"],
      "initializationOptions": {
         "cache": {
           "directory": "/home/agastya/.ccls-cache/"
         },
         "client": {
          "snippetSupport": true
         }
       }
    }
  },
  "coc.preferences.extensionUpdateCheck": "never"
}
